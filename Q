import os
import json
import subprocess

def render_episode(episode_folder):
    """
    Takes episode script.json + scene files and renders final video
    """

    script_path = os.path.join(episode_folder, "script.json")
    output_path = os.path.join(episode_folder, "output")
    os.makedirs(output_path, exist_ok=True)

    with open(script_path, "r") as f:
        data = json.load(f)

    rendered_scenes = []

    for scene in data["scenes"]:
        video = os.path.join(episode_folder, "scenes", "video", scene["video_file"])
        audio = os.path.join(episode_folder, "scenes", "audio", scene["audio_file"])

        temp_output = os.path.join(output_path, f"temp_{scene['id']}.mp4")

        cmd = [
            "ffmpeg",
            "-y",
            "-i", video,
            "-i", audio,
            "-c:v", "copy",
            "-c:a", "aac",
            "-shortest",
            temp_output
        ]

        subprocess.run(cmd)

        rendered_scenes.append(temp_output)

    # Create concat file
    concat_file = os.path.join(output_path, "concat.txt")

    with open(concat_file, "w") as f:
        for scene_file in rendered_scenes:
            f.write(f"file '{scene_file}'\n")

    final_output = os.path.join(output_path, "final_episode.mp4")

    final_cmd = [
        "ffmpeg",
        "-y",
        "-f", "concat",
        "-safe", "0",
        "-i", concat_file,
        "-c", "copy",
        final_output
    ]

    subprocess.run(final_cmd)

    print(f"Final episode rendered: {final_output}")


if __name__ == "__main__":
    render_episode("episodes/episode_01")
